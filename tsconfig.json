{
	"extends": "@vue/tsconfig/tsconfig.json",
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Node",
		"jsx": "preserve",
		"strict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"types": ["vite/client", "@dcloudio/types"]
	},
	"include": ["src/**/*", "env.d.ts"]
}